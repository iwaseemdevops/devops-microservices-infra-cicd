pipeline {
    agent any

    parameters {
        booleanParam(name: 'DESTROY', defaultValue: false, description: 'Destroy infrastructure')
        string(name: 'KEY_NAME', defaultValue: '', description: 'AWS EC2 Key Pair')
    }

    environment {
        AWS_DEFAULT_REGION = 'ap-south-1'
        TF_DIR             = 'terraform-app/envs/dev'
        APP_DIR            = 'microservices-shop'
        EC2_USER           = 'ec2-user'
        KEY_PATH           = "${TF_DIR}/app-key.pem"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/iwaseemdevops/devops-microservices-infra-cicd.git'
            }
        }

        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
                                      credentialsId: 'aws-creds']]) {
                        sh 'terraform init -reconfigure'
                    }
                }
            }
        }

        stage('Terraform Plan') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
                                      credentialsId: 'aws-creds']]) {
                        sh "terraform plan -out=tfplan -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }

        stage('Terraform Apply') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
                                      credentialsId: 'aws-creds']]) {
                        sh "terraform apply -auto-approve tfplan"
                    }
                }
            }
        }

        stage('Fix SSH Key Permissions') {
            when { expression { !params.DESTROY } }
            steps {
                sh "chmod 400 ${KEY_PATH}"
            }
        }

        stage('Fetch EC2 IP') {
            when { expression { !params.DESTROY } }
            steps {
                script {
                    env.EC2_IP = sh(
                        script: "cd ${TF_DIR} && terraform output -raw app_server_public_ip",
                        returnStdout: true
                    ).trim()
                    if (!env.EC2_IP) { error "EC2 IP not found in Terraform output" }
                    echo "EC2 IP: ${env.EC2_IP}"
                }
            }
        }

        stage('Wait for EC2 SSH') {
            when { expression { !params.DESTROY } }
            steps {
                script {
                    echo "Waiting for SSH on ${env.EC2_IP}..."
                    timeout(time: 5, unit: 'MINUTES') {
                        waitUntil {
                            def status = sh(
                                script: "nc -zv ${env.EC2_IP} 22 2>&1",
                                returnStatus: true
                            )
                            if (status == 0) {
                                echo "✅ SSH is available"
                                return true
                            }
                            echo "SSH not ready, retrying in 10s..."
                            sleep 10
                            return false
                        }
                    }
                }
            }
        }

        stage('Copy Application Files') {
            when { expression { !params.DESTROY } }
            steps {
                // Copy entire microservices-shop folder recursively
                sh """
                    scp -r -o StrictHostKeyChecking=no \
                        -i ${KEY_PATH} \
                        ${APP_DIR} \
                        ${EC2_USER}@${env.EC2_IP}:/home/${EC2_USER}/
                """
            }
        }

        stage('Install Docker on EC2') {
            when { expression { !params.DESTROY } }
            steps {
                sh """
                    ssh -o StrictHostKeyChecking=no \
                        -i ${KEY_PATH} ${EC2_USER}@${env.EC2_IP} << EOF
                        sudo amazon-linux-extras install docker -y
                        sudo systemctl start docker
                        sudo systemctl enable docker
                        sudo usermod -aG docker ec2-user
                        sudo curl -fsSL "https://github.com/docker/compose/releases/latest/download/docker-compose-\$(uname -s)-\$(uname -m)" \
                            -o /usr/local/bin/docker-compose
                        sudo chmod +x /usr/local/bin/docker-compose
                        docker --version
                        docker-compose --version
EOF
                """
            }
        }

        stage('Deploy Containers') {
            when { expression { !params.DESTROY } }
            steps {
                sh """
                    ssh -o StrictHostKeyChecking=no \
                        -i ${KEY_PATH} ${EC2_USER}@${env.EC2_IP} << EOF
                        cd /home/ec2-user/microservices-shop
                        sudo /usr/local/bin/docker-compose down || true
                        sudo /usr/local/bin/docker-compose pull
                        sudo /usr/local/bin/docker-compose up -d
EOF
                """
            }
        }

        stage('Terraform Destroy') {
            when { expression { params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
                                      credentialsId: 'aws-creds']]) {
                        sh "terraform destroy -auto-approve -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                if (!params.DESTROY) {
                    echo "✅ Deployment successful! App URL: http://${env.EC2_IP}:3000"
                } else {
                    echo "✅ Infrastructure destroyed successfully."
                }
            }
        }
        failure {
            echo "❌ Pipeline failed. Check logs above for details."
        }
    }
}