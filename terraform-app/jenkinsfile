pipeline {
    agent any

    parameters {
        booleanParam(name: 'DESTROY', defaultValue: false, description: 'Destroy infrastructure')
        string(name: 'KEY_NAME', defaultValue: '', description: 'AWS EC2 Key Pair')
    }

    environment {
        AWS_DEFAULT_REGION = 'ap-south-1'
        TF_DIR = 'terraform-app/envs/dev'
        APP_DIR = 'microservices-shop'
        USER = 'ec2-user'
        SSH_WAIT_TIMEOUT = 300 // seconds
        SSH_WAIT_INTERVAL = 10 // seconds
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/iwaseemdevops/devops-microservices-infra-cicd.git'
            }
        }

        stage('Terraform Init') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        sh 'terraform init -reconfigure'
                    }
                }
            }
        }

        stage('Terraform Plan') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        sh "terraform plan -out=tfplan -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }

        stage('Terraform Apply') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        sh "terraform apply -auto-approve tfplan"
                    }
                }
            }
        }

        stage('Fetch EC2 IP') {
            when { expression { !params.DESTROY } }
            steps {
                script {
                    env.EC2_IP = sh(script: "cd ${TF_DIR} && terraform output -raw app_server_public_ip", returnStdout: true).trim()
                    if (!env.EC2_IP) { error "EC2 IP not found in Terraform output" }
                    echo "EC2 IP: ${env.EC2_IP}"
                }
            }
        }

        stage('Wait for EC2 SSH') {
            when { expression { !params.DESTROY } }
            steps {
                script {
                    echo "Waiting for SSH on ${env.EC2_IP}..."
                    timeout(time: env.SSH_WAIT_TIMEOUT.toInteger(), unit: 'SECONDS') {
                        waitUntil {
                            def status = sh(script: "nc -zv ${env.EC2_IP} 22", returnStatus: true)
                            if (status == 0) { 
                                echo "✅ SSH is available on ${env.EC2_IP}"; 
                                return true 
                            } else { 
                                echo "SSH not ready yet, retrying in ${env.SSH_WAIT_INTERVAL} seconds..."; 
                                sleep env.SSH_WAIT_INTERVAL.toInteger()
                                return false 
                            }
                        }
                    }
                }
            }
        }

        stage('Copy docker-compose') {
            when { expression { !params.DESTROY } }
            steps {
                sh """
                scp -o StrictHostKeyChecking=no \
                ${APP_DIR}/docker-compose.yaml \
                ${USER}@${EC2_IP}:/home/${USER}/
                """
            }
        }

        stage('Deploy Containers') {
            when { expression { !params.DESTROY } }
            steps {
                sh """
                ssh -o StrictHostKeyChecking=no ${USER}@${EC2_IP} << EOF
                docker compose down || true
                docker compose pull
                docker compose up -d
                EOF
                """
            }
        }

        stage('Terraform Destroy') {
            when { expression { params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        sh "terraform destroy -auto-approve -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline finished. Ensuring all Terraform resources are destroyed..."
            dir("${TF_DIR}") {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                    sh "terraform destroy -auto-approve -var='key_name=${params.KEY_NAME}' || echo 'Resources already destroyed or failed'"
                }
            }
        }

        success {
            echo "Deployment successful. App URL: http://${env.EC2_IP}:3000"
        }

        failure {
            echo "Pipeline failed. Automatic cleanup attempted."
        }
    }
}