pipeline {
    agent any

    parameters {
        booleanParam(name: 'DESTROY', defaultValue: false, description: 'Destroy infrastructure')
        string(name: 'KEY_NAME', defaultValue: '', description: 'SSH key pair name for EC2')
    }

    environment {
        AWS_DEFAULT_REGION = 'ap-south-1'
        TF_VERSION = '1.9.7'
        TF_DIR = 'terraform-app/envs/dev'
        APP_DIR = 'microservices-shop'
        BIN_DIR = "${env.HOME}/bin"
        PATH = "${env.HOME}/bin:${env.PATH}"
        USER = "ubuntu"
        RETRIES = 3
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/iwaseemdevops/devops-microservices-infra-cicd.git'
            }
        }

        stage('Setup Terraform') {
            steps {
                sh '''
                    mkdir -p ${BIN_DIR}
                    if ! command -v terraform &> /dev/null; then
                        wget https://releases.hashicorp.com/terraform/${TF_VERSION}/terraform_${TF_VERSION}_linux_amd64.zip
                        unzip -o terraform_${TF_VERSION}_linux_amd64.zip -d ${BIN_DIR}
                        chmod +x ${BIN_DIR}/terraform
                    fi
                    terraform version
                '''
            }
        }

        stage('Terraform Init') {
            when { expression { return !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        sh 'terraform init -reconfigure'
                    }
                }
            }
        }

        stage('Terraform Plan') {
            when { expression { return !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        sh "terraform plan -out=tfplan -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }

        stage('Terraform Apply') {
            when {
                allOf {
                    branch 'main'
                    expression { return !params.DESTROY }
                }
            }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        input message: 'Approve Terraform Apply?'
                        sh "terraform apply -auto-approve tfplan"
                    }
                }
            }
        }

        stage('Get EC2 Public IP') {
            when { expression { return !params.DESTROY } }
            steps {
                script {
                    env.EC2_IP = sh(
                        script: "cd ${TF_DIR} && terraform output -raw app_server_public_ip || echo ''",
                        returnStdout: true
                    ).trim()

                    if (!env.EC2_IP) {
                        error "❌ EC2 Public IP not found! Check Terraform output."
                    }

                    echo "EC2 IP: ${env.EC2_IP}"
                }
            }
        }

        stage('Copy Docker Compose') {
            when { expression { return !params.DESTROY } }
            steps {
                script {
                    retry(env.RETRIES.toInteger()) {
                        sh """
                        scp -o StrictHostKeyChecking=no \
                        ${APP_DIR}/docker-compose.yaml \
                        ${USER}@${EC2_IP}:/home/${USER}/
                        """
                    }
                }
            }
        }

        stage('Deploy Application') {
            when { expression { return !params.DESTROY } }
            steps {
                script {
                    retry(env.RETRIES.toInteger()) {
                        sh """
                        ssh -o StrictHostKeyChecking=no ${USER}@${EC2_IP} << EOF
                        sudo docker compose down || true
                        sudo docker compose pull
                        sudo docker compose up -d
                        EOF
                        """
                    }

                    // Health check
                    sh """
                    ssh -o StrictHostKeyChecking=no ${USER}@${EC2_IP} << EOF
                    for i in {1..10}; do
                        if curl -s http://localhost:3000/health | grep -q 'OK'; then
                            echo '✅ Microservices are up'
                            exit 0
                        else
                            echo 'Waiting for app...'
                            sleep 5
                        fi
                    done
                    echo '❌ App did not respond after 50s'
                    exit 1
                    EOF
                    """
                }
            }
        }

        stage('Terraform Destroy') {
            when { expression { return params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']]) {
                        input message: 'Confirm destroy?'
                        sh "terraform destroy -auto-approve -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }

    }

    post {
        always {
            echo 'Pipeline finished.'
        }

        success {
            archiveArtifacts artifacts: '**/tfplan', fingerprint: true
            echo "Application deployed at http://${env.EC2_IP}:3000"
        }

        failure {
            echo '❌ Pipeline failed. Check logs.'
        }
    }
}