pipeline {
    agent any

    parameters {
        booleanParam(name: 'DESTROY', defaultValue: false, description: 'Destroy infrastructure')
        string(name: 'KEY_NAME', defaultValue: '', description: 'AWS EC2 key pair name')
    }

    environment {
        AWS_DEFAULT_REGION = 'ap-south-1'
        TF_VERSION = '1.9.7'
        TF_DIR = 'terraform-app/envs/dev'
        APP_DIR = 'microservices-shop'
        USER = "ubuntu"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/iwaseemdevops/devops-microservices-infra-cicd.git'
            }
        }

        stage('Install Terraform') {
            steps {
                sh '''
                if ! command -v terraform &> /dev/null; then
                    echo "Installing Terraform ${TF_VERSION}"

                    rm -f terraform terraform_${TF_VERSION}_linux_amd64.zip

                    wget -q https://releases.hashicorp.com/terraform/${TF_VERSION}/terraform_${TF_VERSION}_linux_amd64.zip
                    unzip -o terraform_${TF_VERSION}_linux_amd64.zip

                    sudo mv -f terraform /usr/local/bin/
                fi

                terraform version
                '''
            }
        }

        stage('Terraform Init') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([
                        [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']
                    ]) {
                        sh 'terraform init'
                    }
                }
            }
        }

        stage('Terraform Plan') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([
                        [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']
                    ]) {
                        sh "terraform plan -out=tfplan -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }

        stage('Terraform Apply') {
            when { expression { !params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([
                        [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']
                    ]) {
                        sh "terraform apply -auto-approve tfplan"
                    }
                }
            }
        }

        stage('Get EC2 Public IP') {
            when { expression { !params.DESTROY } }
            steps {
                script {
                    env.EC2_IP = sh(
                        script: "cd ${TF_DIR} && terraform output -raw app_server_public_ip",
                        returnStdout: true
                    ).trim()

                    if (!env.EC2_IP) {
                        error "EC2 Public IP not found"
                    }

                    echo "EC2 IP: ${env.EC2_IP}"
                }
            }
        }

        stage('Wait For EC2 SSH') {
            when { expression { !params.DESTROY } }
            steps {
                sh '''
                echo "Waiting for EC2 SSH..."

                for i in {1..30}
                do
                    nc -z ${EC2_IP} 22 && echo "SSH Ready" && exit 0
                    sleep 10
                done

                echo "EC2 SSH not ready"
                exit 1
                '''
            }
        }

        stage('Copy Docker Compose') {
            when { expression { !params.DESTROY } }
            steps {
                sh '''
                scp -o StrictHostKeyChecking=no \
                ${APP_DIR}/docker-compose.yaml \
                ${USER}@${EC2_IP}:/home/${USER}/
                '''
            }
        }

        stage('Deploy Application') {
            when { expression { !params.DESTROY } }
            steps {
                sh '''
                ssh -o StrictHostKeyChecking=no ${USER}@${EC2_IP} << EOF
                sudo docker compose down || true
                sudo docker compose pull
                sudo docker compose up -d
                EOF
                '''
            }
        }

        stage('Terraform Destroy') {
            when { expression { params.DESTROY } }
            steps {
                dir("${TF_DIR}") {
                    withCredentials([
                        [$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-creds']
                    ]) {
                        sh "terraform destroy -auto-approve -var='key_name=${params.KEY_NAME}'"
                    }
                }
            }
        }

    }

    post {

        success {
            echo "Application deployed successfully"
            echo "Access your app at: http://${env.EC2_IP}:3000"
        }

        failure {
            echo "Pipeline failed. Check logs."
        }

        always {
            echo "Pipeline finished"
        }

    }
}